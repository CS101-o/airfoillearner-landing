---
import { DEMO_URL, WAITLIST_URL } from "../data/site";
import ReadoutCard from "./graphics/ReadoutCard.astro";
---

<section class="cta">
  <div class="shell cta-inner reveal">
    <div class="cta-copy">
      <p class="eyebrow cta-eyebrow">Try it now</p>
      <h2 class="cta-h">Run your first section before you read the docs.</h2>
      <p class="cta-sub">
        No meshing, no licence, no setup. Pick a profile, set the angle, watch the coefficients land
        in milliseconds. The demo is open and free.
      </p>
      <div class="cta-btns">
        <a class="btn btn-primary" href={DEMO_URL}>
          try the live demo →
        </a>
        <a class="btn btn-ghost-light" href={WAITLIST_URL}>join the waitlist</a>
      </div>
    </div>
    <div class="cta-art" aria-hidden="true">
      <ReadoutCard />
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--ink);
    color: var(--paper);
    padding-block: clamp(3.5rem, 7vw, 5.5rem);
  }
  .cta-inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }
  .cta-eyebrow {
    color: #e8896f;
  }
  .cta-h {
    color: var(--paper);
    max-width: 18ch;
    margin-bottom: 1.2rem;
  }
  .cta-sub {
    font-size: 1rem;
    line-height: 1.6;
    color: #c9c4b8;
    max-width: 46ch;
    margin-bottom: 1.9rem;
  }
  .cta-btns {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .cta-art {
    justify-self: end;
  }

  @media (max-width: 820px) {
    .cta-inner {
      grid-template-columns: 1fr;
    }
    .cta-art {
      justify-self: start;
    }
  }
</style>
