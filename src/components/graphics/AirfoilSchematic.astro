---
// Hero line-art: cambered airfoil section at angle of attack, with a faint
// coordinate grid, three streamlines, an AoA arc, and red suction-peak ticks.
---

<svg
  class="airfoil"
  viewBox="0 0 460 320"
  role="img"
  aria-label="Cambered airfoil section at 10 degrees angle of attack, showing flow streamlines and suction-peak pressure markers"
>
  <g class="grid" stroke="var(--grid)" stroke-width="0.5">
    <line x1="0" y1="40" x2="460" y2="40" />
    <line x1="0" y1="80" x2="460" y2="80" />
    <line x1="0" y1="120" x2="460" y2="120" />
    <line x1="0" y1="160" x2="460" y2="160" />
    <line x1="0" y1="200" x2="460" y2="200" />
    <line x1="0" y1="240" x2="460" y2="240" />
    <line x1="0" y1="280" x2="460" y2="280" />
    <line x1="40" y1="0" x2="40" y2="320" />
    <line x1="80" y1="0" x2="80" y2="320" />
    <line x1="120" y1="0" x2="120" y2="320" />
    <line x1="160" y1="0" x2="160" y2="320" />
    <line x1="200" y1="0" x2="200" y2="320" />
    <line x1="240" y1="0" x2="240" y2="320" />
    <line x1="280" y1="0" x2="280" y2="320" />
    <line x1="320" y1="0" x2="320" y2="320" />
    <line x1="360" y1="0" x2="360" y2="320" />
    <line x1="400" y1="0" x2="400" y2="320" />
    <line x1="440" y1="0" x2="440" y2="320" />
  </g>

  <g class="stream" stroke="var(--hair-strong)" stroke-width="0.85" fill="none">
    <path d="M2 70 C140 64, 280 54, 458 76" />
    <path d="M2 104 C140 100, 280 104, 458 112" />
    <path d="M2 238 C140 242, 280 240, 458 232" />
  </g>

  <line
    x1="8"
    y1="166"
    x2="150"
    y2="166"
    stroke="var(--muted)"
    stroke-width="0.5"
    stroke-dasharray="3 3"
  />
  <path d="M52 166 A30 30 0 0 0 80 155" fill="none" stroke="var(--accent)" stroke-width="1" />
  <text x="88" y="161" class="lbl-accent">α = 10°</text>

  <g transform="rotate(7 230 166)">
    <path
      d="M52 166 C88 128, 150 110, 224 111 C300 113, 364 137, 408 161 C362 168, 276 172, 178 172 C120 172, 78 170, 52 166 Z"
      fill="#e9e3d4"
      stroke="var(--ink)"
      stroke-width="1.1"
    />
    <line
      x1="52"
      y1="166"
      x2="408"
      y2="161"
      stroke="var(--ink)"
      stroke-width="0.5"
      stroke-dasharray="4 3"
    />
    <g stroke="var(--accent)" stroke-width="1.5">
      <line x1="138" y1="111" x2="138" y2="92" />
      <line x1="198" y1="111" x2="198" y2="92" />
      <line x1="262" y1="119" x2="262" y2="101" />
    </g>
  </g>

  <text x="406" y="190" class="lbl-mut" text-anchor="end">chord c = 1.0</text>

  <style>
    .airfoil { width: 100%; height: auto; }
    .lbl-accent { font-family: var(--font-mono); font-size: 12px; fill: var(--accent); }
    .lbl-mut { font-family: var(--font-mono); font-size: 11px; fill: var(--muted); }
  </style>
</svg>
