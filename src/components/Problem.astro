---
const stats = [
  {
    figure: "£75k–£2.5M",
    label: "what a single 500-run 3D RANS design campaign costs in compute.",
  },
  {
    figure: "30–40%",
    label: "of an engineer's time goes to re-running simulations after a bad setup.",
  },
  {
    figure: "a few dozen",
    label: "geometries actually get evaluated, out of the thousands worth trying.",
  },
];
---

<section class="section problem" id="problem">
  <div class="shell">
    <div class="problem-head reveal">
      <p class="eyebrow eyebrow--muted">The problem</p>
      <p class="lead">
        High-fidelity CFD is the bottleneck in early aerodynamic design. It's slow, it's expensive,
        and one wrong setup can burn a day of compute — so engineers test a handful of shapes when
        they should be testing thousands.
      </p>
    </div>

    <div class="stat-row">
      {
        stats.map((s) => (
          <div class="stat reveal">
            <p class="figure">{s.figure}</p>
            <p class="figure-label">{s.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .problem-head {
    max-width: 56ch;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .stat-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--hair);
    border: 1px solid var(--hair);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .stat {
    background: var(--paper-2);
    padding: 1.75rem;
  }
  .figure {
    font-family: var(--font-mono);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
    margin: 0 0 0.7rem;
  }
  .figure-label {
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--muted);
    margin: 0;
  }

  @media (max-width: 720px) {
    .stat-row {
      grid-template-columns: 1fr;
    }
  }
</style>
