---
import { DEMO_URL, CONTACT_EMAIL } from "../data/site";

const team = [
  { name: "Baramee Thanawarothon", role: "Co-founder · BD & partnerships" },
  { name: "Kaan", role: "Co-founder · technical lead" },
  { name: "Jackie", role: "Commercial" },
];
---

<footer class="footer" id="footer">
  <div class="shell">
    <div class="foot-top">
      <div class="foot-brand">
        <div class="brand">
          <svg width="30" height="16" viewBox="0 0 60 26" aria-hidden="true">
            <path d="M4 18 C18 7, 40 5, 58 13 C40 16, 22 17, 4 18 Z" fill="var(--ink)"></path>
            <path
              d="M4 18 C18 7, 40 5, 58 13"
              fill="none"
              stroke="var(--accent)"
              stroke-width="1.4"></path>
          </svg>
          <span class="brand-name">AirfoilLearner</span>
        </div>
        <p class="foot-line">
          An ML surrogate that screens airfoil geometries before they reach your CFD solver.
        </p>
        <p class="foot-prog mono">University of Manchester · Masood Entrepreneurship Centre</p>
      </div>

      <div class="foot-cols">
        <div class="foot-col">
          <p class="foot-h">Product</p>
          <a href={DEMO_URL} target="_blank" rel="noopener">Live demo</a>
          <a href="#how-it-works">How it works</a>
          <a href="#science">The science</a>
        </div>
        <div class="foot-col">
          <p class="foot-h">Team</p>
          {
            team.map((t) => (
              <span class="foot-person">
                {t.name}
                <em>{t.role}</em>
              </span>
            ))
          }
        </div>
        <div class="foot-col">
          <p class="foot-h">Contact</p>
          <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
          <a href="https://www.linkedin.com/" target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
    </div>

    <hr class="rule" />
    <div class="foot-bottom">
      <span class="mono">© 2026 AirfoilLearner</span>
      <span class="mono">Built in Manchester</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--paper);
    border-top: 1px solid var(--hair);
    padding-block: clamp(3rem, 6vw, 4.5rem) 2rem;
  }
  .foot-top {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(2rem, 5vw, 4rem);
    margin-bottom: 2.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .brand-name {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink);
  }
  .foot-line {
    font-size: 0.95rem;
    color: var(--muted);
    max-width: 38ch;
    margin-bottom: 0.9rem;
  }
  .foot-prog {
    font-size: 0.72rem;
    color: var(--muted);
  }
  .foot-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .foot-h {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0 0 0.9rem;
  }
  .foot-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.9rem;
  }
  .foot-col a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
    width: fit-content;
  }
  .foot-col a:hover {
    color: var(--ink);
  }
  .foot-person {
    display: flex;
    flex-direction: column;
    color: var(--ink);
    font-size: 0.9rem;
  }
  .foot-person em {
    font-style: normal;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .foot-bottom {
    display: flex;
    justify-content: space-between;
    padding-top: 1.4rem;
    font-size: 0.72rem;
    color: var(--muted);
  }

  @media (max-width: 820px) {
    .foot-top {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .foot-cols {
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }
  }
</style>
